+    if (left.length != right.length) {
+      return false;
+    }
+    for (final entry in left.entries) {
+      final rightValues = right[entry.key];
+      if (rightValues == null ||
+          rightValues.length != entry.value.length ||
+          !rightValues.containsAll(entry.value)) {
+        return false;
