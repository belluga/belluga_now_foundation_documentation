+          .where((value) => value.isNotEmpty)
+          .toSet(),
+      taxonomyTermKeys: <String, Set<String>>{
+        for (final taxonomy in snapshot.taxonomySelections)
+          if (!taxonomy.isEmpty)
+            taxonomy.taxonomyKey.value: taxonomy.termKeys
+                .map((value) => value.value)
+                .where((value) => value.isNotEmpty)
+                .toSet(),
+      },
+    );
+  }
