+    private function htmlParagraphOfSanitizedByteLength(int $targetBytes): string
+    {
+        $wrapperBytes = strlen('<p></p>');
+        $bodyBytes = max(0, $targetBytes - $wrapperBytes);
+
+        return '<p>'.str_repeat('a', $bodyBytes).'</p>';
+    }
