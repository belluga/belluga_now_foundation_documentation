+  required TenantAdminEventDateTimePicker pickDateTime,
+  required TenantAdminEventRelatedProfilePicker pickRelatedAccountProfile,
+  required TenantAdminEventModalCloser closeModalSheet,
+}) {
+  final existing =
+      index == null || index < 0 || index >= formState.occurrences.length
+          ? null
+          : formState.occurrences[index];
+  final fallbackStart = formState.occurrences.isNotEmpty
+      ? formState.occurrences.last.dateTimeStart.add(const Duration(days: 1))
+      : formState.startAt ?? DateTime.now();
+  final fallbackEnd = formState.endAt == null || formState.startAt == null
+      ? null
+      : fallbackStart.add(formState.endAt!.difference(formState.startAt!));
