+      },
+      location: {
+        mode: 'physical',
+      },
+      place_ref: {
+        type: 'account_profile',
+        id: physicalHost.id,
+      },
+      event_parties: [],
+      occurrences: [
+        {
+          date_time_start: start.toISOString(),
+          date_time_end: end.toISOString(),
+        },
+      ],
