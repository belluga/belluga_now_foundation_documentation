+      if (!isVisibleInViewport(box, viewport)) {
+        continue;
+      }
+      await page.mouse.move(box.x + box.width / 2, box.y + box.height / 2);
+      await page.mouse.wheel(targetTitle === 'Sobre' ? -900 : 900, 0);
+      return;
+    }
+  }
