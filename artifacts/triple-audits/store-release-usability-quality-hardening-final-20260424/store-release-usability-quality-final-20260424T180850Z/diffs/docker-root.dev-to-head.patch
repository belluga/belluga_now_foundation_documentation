+        return;
+      }
+      if ((await countTextInViewport(page, confirmationTextInViewport)) > 0) {
+        return;
+      }
+    }
+    for (const point of fallbackImmersiveTabClickPoints(page, title)) {
+      await page.mouse.click(point.x, point.y);
+      await page.waitForTimeout(650);
+      if (!confirmationTextInViewport) {
+        return;
+      }
+      if ((await countTextInViewport(page, confirmationTextInViewport)) > 0) {
+        return;
+      }
+    }
+    await scrollVisibleImmersiveTabBar(page, title);
+    await page.waitForTimeout(250);
