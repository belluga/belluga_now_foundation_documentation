+
+  await clickBackAffordance(page, 'Discovery');
+  await expect(page).toHaveURL(/\/($|#\/?$|\?)/, { timeout: appBootTimeoutMs });
+  expect(page.url()).not.toBe(openedDetailUrl);
+});
