+async function clickPublicAgendaCardAndWaitForDetail(page, titlePattern) {
+  const titleBox = await findVisibleTextBox(page, titlePattern);
+  expect(titleBox, 'Public agenda card title must have a visible hit target.')
+    .toBeTruthy();
+  const viewport =
+    page.viewportSize() ||
+    (await page.evaluate(() => ({
+      width: window.innerWidth,
+      height: window.innerHeight,
+    })));
+  const y = titleBox.y + titleBox.height / 2;
+  const clickPoints = [
+    [titleBox.x + titleBox.width / 2, y],
+    [Math.min(viewport.width - 42, titleBox.x + titleBox.width + 180), y],
+    [viewport.width - 42, y],
+  ];
+
+  for (const [x, clickY] of clickPoints) {
+    await page.mouse.click(x, clickY);
+    const opened = await page
+      .waitForURL(/\/agenda\/evento\//, { timeout: 5000 })
+      .then(() => true)
+      .catch(() => false);
+    if (opened) {
+      return true;
+    }
+  }
+  return /\/agenda\/evento\//.test(page.url());
+}
