+function fallbackImmersiveTabClickPoints(page, title) {
+  const viewport = page.viewportSize() || { width: 1280, height: 720 };
+  const centerX = viewport.width / 2;
+  const tabYCandidates = [
+    viewport.height * 0.11,
+    viewport.height * 0.145,
+    viewport.height * 0.59,
+    viewport.height * 0.22,
+    82,
+    104,
+    424,
+    162,
+  ];
+  const offsetsByTitle = {
+    Sobre: [-55, -25, 0],
+    Programação: [-8, 20, 48],
+    'Como Chegar': [36, 66, 96, 126, 156, 186],
+  };
+  const offsets = offsetsByTitle[title] || [0];
+  const points = [];
+  for (const y of tabYCandidates) {
+    if (y < 0 || y > viewport.height) {
+      continue;
+    }
+    for (const offset of offsets) {
+      const x = centerX + offset;
+      if (x < 0 || x > viewport.width) {
+        continue;
+      }
+      points.push({ x, y });
+    }
+  }
+  return points;
+}
