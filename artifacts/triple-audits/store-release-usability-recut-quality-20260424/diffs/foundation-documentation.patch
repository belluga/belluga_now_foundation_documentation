-{
-  "_id": "ObjectId()",
-  "account_profile_id": "ObjectId()",
-  "tenant_id": "ObjectId()",
-  "name": "String",
-  "category": "String",
-  "subcategories": ["String"],
-  "pricing`: {
-    "currency": "String",
