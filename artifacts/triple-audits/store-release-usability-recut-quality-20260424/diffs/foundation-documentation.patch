-  "tagline": "String",
-  "description": "String",
-  "media": {
-    "hero_image": "String",
-    "logo": "String",
-    "gallery": ["String"]
-  },
-  "contact_channels": [
-    { "type": "String", "value": "String", "is_verified": "Boolean" }
-  ],
-  "location": {
-    "address": "String",
-    "lat": "Number",
-    "lng": "Number",
-    "geohash": "String"
-  },
-  "badges": ["String"],
-  "verification_flags": ["String"],
-  "created_at": "Date",
-  "updated_at": "Date"
-}
-```
-
-### 3.2 `offers`
