# Local web navigation smoke defaults.
# Copy to .env.local.navigation or run tools/flutter/setup_local_navigation_env.sh.
# .env.local.navigation is gitignored and may contain local-only credentials.

NAV_LANDLORD_URL=https://belluga.space
NAV_TENANT_URL=https://guarappari.belluga.space
NAV_DEPLOY_LANE=dev
PLAYWRIGHT_IGNORE_HTTPS_ERRORS=true

