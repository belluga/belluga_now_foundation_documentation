APP_ENV=local
# Docker compose profiles (comma-separated). Examples:
# - local-db
# - local-tunnel
# - production
COMPOSE_PROFILES=
PROJECT_NAME=project_name
PROJECT_PREFIX=project_prefix
DOMAIN=domain
CERTBOT_EMAIL=email
NGINX_HOST_PORT_80=8081
NGINX_HOST_PORT_443=8043
LOG_CHANNEL=stack
LOG_STACK=mongodb,stderr
LOG_LEVEL=info
LOG_MONGODB_URI=mongodb://mongo:27017/belluga_logs
LOG_MONGODB_DATABASE=belluga_logs
LOG_MONGODB_COLLECTION=application_logs
LOG_MONGODB_RETENTION_DAYS=14
