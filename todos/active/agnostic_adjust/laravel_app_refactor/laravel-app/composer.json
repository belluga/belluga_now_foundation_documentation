{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-mongodb": "^2.0",
        "intervention/image": "^3.11",
        "intervention/image-laravel": "^1.5",
        "kreait/firebase-php": "^7.0",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.10.1",
        "mongodb/laravel-mongodb": "^5.4",
        "propaganistas/laravel-phone": "^6.0",
        "spatie/laravel-data": "^4.17",
        "spatie/laravel-multitenancy": "^4.0",
        "spatie/laravel-sluggable": "^3.7"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3"
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/belluga/belluga_media"
        },
        {
            "type": "path",
            "url": "packages/belluga/belluga_rich_text"
        },
        {
            "type": "path",
            "url": "packages/belluga/belluga_events"
        },
        {
            "type": "path",
            "url": "packages/belluga/belluga_settings"
        },
        {
            "type": "path",
            "url": "packages/belluga/belluga_push_handler"
        },
        {
            "type": "path",
            "url": "packages/belluga/belluga_map_pois"
        },
        {
            "type": "path",
            "url": "packages/belluga/belluga_discovery_filters"
        },
        {
            "type": "path",
            "url": "packages/belluga/belluga_invites"
        },
        {
            "type": "path",
            "url": "packages/belluga/belluga_favorites"
        },
        {
            "type": "path",
            "url": "packages/belluga/belluga_deep_links"
        },
        {
            "type": "path",
            "url": "packages/belluga/belluga_email"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Belluga\\RichText\\": "packages/belluga/belluga_rich_text/src/",
            "Belluga\\Events\\": "packages/belluga/belluga_events/src/",
            "Belluga\\Settings\\": "packages/belluga/belluga_settings/src/",
            "Belluga\\PushHandler\\": "packages/belluga/belluga_push_handler/src/",
            "Belluga\\Invites\\": "packages/belluga/belluga_invites/src/",
            "Belluga\\MapPois\\": "packages/belluga/belluga_map_pois/src/",
            "Belluga\\DiscoveryFilters\\": "packages/belluga/belluga_discovery_filters/src/",
            "Belluga\\Favorites\\": "packages/belluga/belluga_favorites/src/",
            "Belluga\\Media\\": "packages/belluga/belluga_media/src/",
            "Belluga\\DeepLinks\\": "packages/belluga/belluga_deep_links/src/",
            "Belluga\\Email\\": "packages/belluga/belluga_email/src/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "architecture:guardrails": [
            "@php scripts/architecture_guardrails.php"
        ],
        "lint:strict": [
            "@php ./vendor/bin/pint --test",
            "@composer run architecture:guardrails"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
