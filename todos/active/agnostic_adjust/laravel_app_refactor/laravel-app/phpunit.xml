<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         stopOnFailure="true"
         colors="true"
>
    <testsuites>
        <testsuite name="Feature-Initialization">
            <directory>tests/Feature/Initialization</directory>
        </testsuite>
        <testsuite name="Feature-Landlord">
            <directory>tests/Feature/Landlord</directory>
        </testsuite>
        <testsuite name="Feature-Accounts">
            <directory>tests/Feature/Accounts</directory>
        </testsuite>
        <testsuite name="Feature-AccountProfiles">
            <directory>tests/Feature/AccountProfiles</directory>
        </testsuite>
        <testsuite name="Feature-Events">
            <directory>tests/Feature/Events</directory>
        </testsuite>
        <testsuite name="Feature-Map">
            <directory>tests/Feature/Map</directory>
        </testsuite>
        <testsuite name="Feature-StaticAssets">
            <directory>tests/Feature/StaticAssets</directory>
        </testsuite>
        <testsuite name="Feature-Taxonomies">
            <directory>tests/Feature/Taxonomies</directory>
        </testsuite>
        <testsuite name="Feature-Tenants">
