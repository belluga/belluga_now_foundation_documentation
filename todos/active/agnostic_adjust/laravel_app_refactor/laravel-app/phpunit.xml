            <file>tests/Api/v1/Admin/ApiV1AdminUserTest.php</file>
            <file>tests/Api/v1/Admin/ApiV1AdminAuthTest.php</file>
            <file>tests/Api/v1/Admin/ApiV1AdminProfileTest.php</file>
            <file>tests/Api/v1/Admin/ApiV1AdminTenantTest.php</file>
            <file>tests/Api/v1/Admin/ApiV1BrandingAdminTest.php</file>
        </testsuite>
